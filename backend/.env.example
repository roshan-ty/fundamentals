# ──────────────────────────────────────────────
# Bulls & Bears Fundamentals — API Key Configuration
# ──────────────────────────────────────────────
# Replace placeholder values with your actual API keys.
# NEVER commit the .env file to version control.
# In GitHub Actions, these are set as repository Secrets.

# FRED (Federal Reserve Economic Data)
FRED_API_KEY=your_fred_api_key_here

# AlphaVantage (Stock & Economic Indicators)
ALPHAVANTAGE_API_KEY=your_alphavantage_api_key_here

# Finnhub (Financial Data & Economic Calendar)
FINNHUB_API_KEY=your_finnhub_api_key_here

# Twelve Data (Market Data)
TWELVEDATA_API_KEY=your_twelvedata_api_key_here

# Financial Modeling Prep (FMP)
FMP_API_KEY=your_fmp_api_key_here

# Newsdata.io (Financial News Feed)
NEWSDATA_API_KEY=your_newsdata_api_key_here

# EODHD (Economic Calendar & Historical Data)
EODHD_API_KEY=your_eodhd_api_key_here

# MarketStack (Real-time & Historical Market Data)
MARKETSTACK_API_KEY=your_marketstack_api_key_here

# xAI (AI Macro Analysis Engine)
XAI_API_KEY=your_xai_api_key_here